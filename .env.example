# SolarPR Monitor — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# En Vercel: Settings → Environment Variables.

# URL del webhook de Google Apps Script (termina en /exec).
# Es la "base de datos" de usuarios e instalaciones en Google Sheets.
GOOGLE_SHEETS_WEBHOOK_URL=

# "Pepper" secreto que se mezcla con las contraseñas antes de hashearlas.
# Pon una cadena larga y aleatoria. ⚠️ Si la cambias, los usuarios existentes
# no podrán entrar (sus hashes se generaron con otro pepper).
PASSWORD_PEPPER=

# Token secreto compartido con el Apps Script (variable API_SECRET en Code.gs).
# Evita que cualquiera que descubra la URL del webhook escriba en tu Sheets.
API_SECRET=

# (Opcional, solo modo local Windows) Ruta del acceso directo a Lectucont.
# Si no se indica, se usa la ruta por defecto del menú Inicio.
LECTUCONT_APPREF_PATH=

# (Opcional) Configuración SIAR. Si no se indica, se usan los valores por defecto.
SIAR_WEB_BASE_URL=
SIAR_RADIATION_VARIABLE_ID=
SIAR_DAILY_TIPO_CALCULO=
